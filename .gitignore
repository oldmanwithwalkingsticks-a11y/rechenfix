# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files — secrets are never committed.
# Whitelist .env.example (template ohne echte Werte) bei Bedarf.
.env
.env.*
!.env.example

# sensitive documents
Dokumente/Claude Api Key.txt
Dokumente/GitHub Token.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local settings (maschinenspezifisch)
.claude/settings.local.json

# Generierte Reports (Quell-Code ist committed, Output nicht)
/reports/

# Lokale Working-Files / persönliche Arbeitskopien (W15C-T5 Cleanup)
# Diese Dateien entstehen lokal beim Recherchieren/Debuggen und gehören
# nicht ins Repo. Falls Du eine davon teilen willst, in docs/ verschieben
# und bewusst committen.
/brutto-netto-raw.html
/history-check.*
/sitemap-live-*.xml
/doku-sync-*-patch.md

# W15C-T7 — Auto-generierte Inline-Critical-CSS (siehe scripts/build-critical-css.mjs)
# Wird per `prebuild`-Hook bei jedem `npm run build` neu erzeugt.
/lib/critical-css.ts
/tmp/

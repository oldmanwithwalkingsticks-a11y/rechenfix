# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files — secrets are never committed.
# Whitelist .env.example (template ohne echte Werte) bei Bedarf.
.env
.env.*
!.env.example

# sensitive documents
Dokumente/Claude Api Key.txt
Dokumente/GitHub Token.txt

# Secrets / Tokens (nie committen) — W17A
docs/audit-arbeitspapiere/welle17a-tokens.txt
*tokens.txt
*.secret

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code local settings (maschinenspezifisch)
.claude/settings.local.json

# Generierte Reports (Quell-Code ist committed, Output nicht)
/reports/

# Lokale Working-Files / persönliche Arbeitskopien (W15C-T5 Cleanup)
# Diese Dateien entstehen lokal beim Recherchieren/Debuggen und gehören
# nicht ins Repo. Falls Du eine davon teilen willst, in docs/ verschieben
# und bewusst committen.
/brutto-netto-raw.html
/history-check.*
/sitemap-live-*.xml
/doku-sync-*-patch.md

# W15C-T7 / fix/critical-css — Auto-generierte CSS-Artefakte (siehe
# scripts/build-critical-css.mjs). Pro `npm run build` neu erzeugt.
/lib/critical-css.ts
/public/styles/
/tmp/

# W17A.1.F — Auto-generierter Rechner-Snapshot für Python-Image-Builder
# (scripts/dump-rechner-data.ts). Wird pro Image-Build neu erzeugt.
/lib/social/_rechner-snapshot.json
# Generierte Social-Bilder (160 Slugs) — separat in eigener Konvention,
# Karsten committed sie nach social-image-builder.py-Run gesammelt.
# Initial NICHT auf gitignore-Liste, damit die Bilder versioniert werden.

# Vercel Deploy Hook (Trigger-Token, nicht committen)
.vercel-deploy-hook

.vercel
.env*

# Lokales Render-Werkzeug: NotoColorEmoji für den Image-Builder
# (SOCIAL_FONT_EMOJI). Nur lokal, wird NICHT committet.
.fonts/

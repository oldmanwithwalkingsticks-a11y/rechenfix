{
  "name": "rechenfix",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate-client-data": "npx tsx scripts/generate-client-data.ts",
    "prebuild": "node scripts/check-footer.mjs && node scripts/check-jahreswerte.mjs && node scripts/check-backticks.mjs && node scripts/slug-drift-scan.mjs && npx tsx scripts/generate-client-data.ts && npx tsx scripts/generate-tipp-constants.ts",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:jahreswerte": "node scripts/check-jahreswerte.mjs",
    "lint:footer": "node scripts/check-footer.mjs",
    "lint:slugs": "node scripts/slug-drift-scan.mjs",
    "audit:bundle": "npx tsx scripts/build-audit-bundle.ts",
    "audit:wortzahl": "npx tsx scripts/wortzahl-audit.mjs > docs/audit-arbeitspapiere/w15c-wortzahl-audit.csv",
    "longtail:diff": "node scripts/longtail-diff-check.mjs"
  },
  "dependencies": {
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "decimal.js": "^10.6.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^6.10.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "browserslist": {
    "production": [
      "chrome >= 87",
      "firefox >= 78",
      "safari >= 14",
      "edge >= 88"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
